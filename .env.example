# Aegis Vault 配置
PORT=46746
AEGIS_DATA_DIR=./data
TEMPLATE_DIR=./templates
CHECKIN_TIMEOUT=72
# CHECKIN_TIMEOUT_SECONDS=60  # 仅测试时使用，优先级高于 CHECKIN_TIMEOUT
MONITOR_INTERVAL_SECONDS=5
SESSION_TTL_HOURS=12
SESSION_COOKIE_NAME=aegis_session
SESSION_COOKIE_SECURE=false
MAX_VAULT_SIZE_MB=1024
MAX_UPLOAD_SIZE_MB=64
AUDIT_LOG_DIR=./data
SECRET_SCRYPT_N=32768
SECRET_SCRYPT_R=8
SECRET_SCRYPT_P=1
SECRET_SCRYPT_MAXMEM=134217728

# ============ 安全性建议 ============
# 1. 启用 HTTPS 并设置 SESSION_COOKIE_SECURE=true（生产环境必须）
# 2. 配置全磁盘加密 (LUKS/BitLocker) - 参考 docs/security-hardening.md
# 3. 定期备份审计日志到安全存储
# 4. 限制 AEGIS_DATA_DIR 目录的文件系统权限 (755 for dir, 600 for keys)
# 5. 使用 systemd 的 ProtectSystem=strict 等安全特性运行服务
# 6. 启用 SELinux 或 AppArmor 沙箱
